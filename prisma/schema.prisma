generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  PHARMACIST
  OWNER
}

enum AlertType {
  LOW_STOCK
  EXPIRY_RISK
  STOCKOUT
  REORDER
  EXPIRY_LIQUIDATION
  STOCKOUT_RISK
}

enum AlertSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(PHARMACIST)
  isActive     Boolean  @default(true)
  sales        Sale[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Medicine {
  id            String           @id @default(cuid())
  sku           String           @unique
  name          String
  genericName   String?
  category      String
  unitPrice     Decimal          @db.Decimal(10, 2)
  reorderPoint  Int              @default(50)
  scheduleType  String?
  avgDailySales Float            @default(10)
  batches       Batch[]
  forecasts     ForecastRecord[]
  alerts        Alert[]
  saleItems     SaleItem[]
  supplier      Supplier?        @relation(fields: [supplierId], references: [id])
  supplierId    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Batch {
  id           String   @id @default(cuid())
  batchNumber  String
  expiryDate   DateTime
  quantity     Int
  medicine     Medicine @relation(fields: [medicineId], references: [id])
  medicineId   String
  createdAt    DateTime @default(now())
}

model Patient {
  id          String           @id @default(cuid())
  name        String
  nic         String?          @unique
  phone       String?
  consentFlag Boolean          @default(false)
  history     PatientHistory[]
  sales       Sale[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model PatientHistory {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  notes     String?
  patient   Patient  @relation(fields: [patientId], references: [id])
  patientId String
}

model Supplier {
  id          String     @id @default(cuid())
  name        String
  contactInfo String?
  medicines   Medicine[]
  createdAt   DateTime   @default(now())
}

model Sale {
  id          String     @id @default(cuid())
  saleDate    DateTime   @default(now())
  totalAmount Decimal    @db.Decimal(10, 2)
  patient     Patient?   @relation(fields: [patientId], references: [id])
  patientId   String?
  user        User       @relation(fields: [userId], references: [id])
  userId      String
  saleItems   SaleItem[]
  createdAt   DateTime   @default(now())
}

model SaleItem {
  id          String   @id @default(cuid())
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  totalAmount Decimal  @db.Decimal(10, 2)
  sale        Sale     @relation(fields: [saleId], references: [id])
  saleId      String
  medicine    Medicine @relation(fields: [medicineId], references: [id])
  medicineId  String
}

model ForecastRecord {
  id              String   @id @default(cuid())
  predictedDemand Int
  confidenceScore Float
  forecastPeriod  String
  generatedAt     DateTime @default(now())
  medicine        Medicine @relation(fields: [medicineId], references: [id])
  medicineId      String
}

model Alert {
  id         String        @id @default(cuid())
  alertType  AlertType
  severity   AlertSeverity @default(MEDIUM)
  message    String
  metadata   String?
  isResolved Boolean       @default(false)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())
  medicine   Medicine      @relation(fields: [medicineId], references: [id])
  medicineId String
}
